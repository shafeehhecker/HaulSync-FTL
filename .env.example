# Copy to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=haulsync
DB_PASSWORD=haulsync_secret
DB_NAME=haulsync_ftl

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_32_chars_minimum
JWT_EXPIRES_IN=7d

# ── App URLs ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5001
FRONTEND_URL=http://localhost:3001
NODE_ENV=production

# ── GPS Integration ───────────────────────────────────────────────────────────
GPS_PROVIDER=mock
GPS_API_KEY=
GPS_WEBHOOK_SECRET=

# ── E-Way Bill (NIC) ──────────────────────────────────────────────────────────
EWAY_CLIENT_ID=
EWAY_CLIENT_SECRET=
EWAY_GSTIN=

# ── HaulSync Core (optional) ──────────────────────────────────────────────────
HAULSYNC_CORE_URL=
HAULSYNC_CORE_API_KEY=
