# ── Database ─────────────────────────────────────────────────────────────────
DB_USER=haulsync
DB_PASSWORD=haulsync_secret
DB_NAME=haulsync_ftl

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_32_chars_minimum

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5001

# ── GPS Integration ───────────────────────────────────────────────────────────
# Options: mock | vamosys | locus | uffizio | trackpoint | rosmerta | rivigo
GPS_PROVIDER=mock
GPS_API_KEY=

# ── E-Way Bill (NIC) ──────────────────────────────────────────────────────────
EWAY_CLIENT_ID=
EWAY_CLIENT_SECRET=
EWAY_GSTIN=

# ── HaulSync Core Integration (optional) ─────────────────────────────────────
# Set these to share master data (vendors, vehicles, drivers) with a running
# HaulSync core instance. Leave blank for standalone mode.
HAULSYNC_CORE_URL=
HAULSYNC_CORE_API_KEY=

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV=production
